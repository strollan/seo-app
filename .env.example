# Copy this to .env locally or set these in your web host environment.
# Do NOT put real secrets in this example file.

# === OpenAI ===
OPENAI_API_KEY=

# === LeadBot SERP provider ===
# Recommended production:
# LEADBOT_SERP_PROVIDER=dataforseo
LEADBOT_SERP_PROVIDER=dataforseo
USE_LIVE_SERP=1

# === DataForSEO ===
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_ENABLED=1
LEADBOT_DATAFORSEO_ENABLED=1
DATAFORSEO_MODE=organic
DATAFORSEO_DEPTH=60
DATAFORSEO_LANGUAGE_CODE=en
DATAFORSEO_DEVICE=desktop
DATAFORSEO_OS=windows
LEADBOT_ORGANIC_ONLY=1

# === Google / fallback APIs ===
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
SERPER_API_KEY=

# Keep Places disabled for main LeadBot scans if you want organic SERP-first leads.
LEADBOT_DISABLE_PLACES_MAIN=1

# === Cookies / production security ===
# Local dev can leave this 0.
# Production HTTPS should set this to 1.
APP_COOKIE_SECURE=1

# === Password reset / email ===
# Leave SMTP_HOST blank in local dev — the reset link will print to the console instead.
# Set all of these in production to enable real email delivery.
APP_BASE_URL=https://yourdomain.com
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASSWORD=
SMTP_FROM=no-reply@yourdomain.com
